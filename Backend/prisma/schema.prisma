generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   UserProfile?
  expenses  Expense[]
}

model UserProfile {
  id              String   @id @default(uuid())

  monthlyIncome   Decimal
  savingsGoal     Decimal

  currency        String   @default("INR")


  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
}

enum ExpenseCategory {
  FOOD
  RENT
  TRANSPORT
  SHOPPING
  ENTERTAINMENT
  LIFESTYLE
  HEALTH
  EDUCATION
  UTILITIES
  TRAVEL
  DATING
  OTHER
}

model Expense {
  id          String            @id @default(uuid())

  amount      Decimal

  category    ExpenseCategory

  notes       String?

  expenseDate DateTime

  receiptUrl  String?

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId      String
  user        User              @relation(fields: [userId], references: [id])
}